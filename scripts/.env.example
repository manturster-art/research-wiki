# OpenAlex × LLM Wiki — 환경 변수 예시
# 이 파일을 _workspace/.env 로 복사한 후 실제 키를 채워 넣으세요.
# .env 는 .gitignore 처리해서 절대 커밋하지 않습니다.

# 1) OpenAlex API Key (권장, 무료, 30초)
#    발급: https://openalex.org/settings/api
#    예산: 키 사용 시 일 $1 (≈ list 10K건 / search 1K건), 미사용 시 $0.01로 제한
OPENALEX_KEY=

# 2) (선택) 구식 polite pool 이메일, 키가 없을 때 fallback
#    2026-02-13 정책 변경으로 점진적으로 단종 예정
OPENALEX_MAILTO=manturster@gmail.com

# 3) Crossref polite pool (키 불필요, mailto만)
#    api.crossref.org/swagger-ui — 두 번째 독립 ground truth로 OpenAlex와 cross-check
#    미설정 시 일반 풀로 동작 (rate limit 더 낮음).
#    비워두면 OPENALEX_MAILTO를 fallback으로 사용.
CROSSREF_MAILTO=

# 4) KCI Open API (한국학술지인용색인)
#    발급: https://www.kci.go.kr/kciportal/po/openapi/openApiList.kci
#    ⚠️ IP whitelist 방식 — 등록한 로컬 PC에서만 동작 (Claude Code 원격 환경 불가)
#    kci_helper.js 에서 사용. CLI: node _workspace/kci_helper.js diagnose
KCI_API_KEY=
